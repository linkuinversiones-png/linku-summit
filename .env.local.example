# Supabase — llaves del proyecto
# Cómo conseguirlas: Supabase Dashboard → Project Settings → API
# Copia los valores y pega aquí. Después renombra este archivo a ".env.local"

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (opcional) Service Role key — solo para operaciones server-side de admin.
# Si no la usas, déjala vacía. NUNCA la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# (opcional) Nombre del bucket de Storage para imágenes de la landing
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=summit-media
