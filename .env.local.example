# =====================================================================
# Supabase — llaves del proyecto
# Cómo conseguirlas: Supabase Dashboard → Project Settings → API
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service Role key — necesaria para que el webhook de ePayco
# pueda escribir en orders/tickets_issued sin sesión de usuario.
# NUNCA la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (opcional) Para aplicar migraciones via scripts/run-migrations.mjs
SUPABASE_PROJECT_REF=xxxxxxxxxxxx
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bucket de Storage para fotos de speakers, sponsors, etc.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=summit-media

# =====================================================================
# ePayco — pasarela de pagos
# Cómo conseguirlas: Dashboard ePayco → Integraciones → Llaves API
# El modo (Pruebas/Producción) se controla con el toggle en el dashboard;
# las llaves que ves corresponden al modo activo. Empezar siempre en pruebas.
#
# Mapeo de los nombres que ePayco da → nuestras env vars:
#   P_CUST_ID_CLIENTE → EPAYCO_CUSTOMER_ID
#   PUBLIC_KEY        → EPAYCO_PUBLIC_KEY
#   PRIVATE_KEY       → EPAYCO_PRIVATE_KEY  (server-only, API REST)
#   P_KEY             → EPAYCO_P_KEY        (server-only, firma SHA256)
# =====================================================================
EPAYCO_TEST_MODE=true
EPAYCO_CUSTOMER_ID=xxxxxxx
EPAYCO_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EPAYCO_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EPAYCO_P_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# Resend — envío de emails (boleta + QR, notificaciones)
# La cuenta ya está conectada a Supabase Auth para los magic links;
# esta llave es para los emails transaccionales nuestros.
# Dashboard Resend → API Keys
# =====================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =====================================================================
# QR — secret HMAC para firmar tokens de boletas
# Debe ser una cadena LARGA y aleatoria (mín. 32 chars). Una vez en
# producción NO se debe cambiar (invalidaría QRs ya emitidos).
# Genera una: `openssl rand -hex 32`  o cualquier random fuerte.
# =====================================================================
QR_HMAC_SECRET=cambia-esto-por-32-caracteres-random-en-prod

# =====================================================================
# Site URL — usado para construir URLs de QR, redirects, email links
# Local: http://localhost:3000
# Prod:  https://linkusummit.com
# =====================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
